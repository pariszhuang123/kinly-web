# --------------------------------------------------
# Kinly Web — Environment Variables (Example)
# Copy to .env.local and fill in values.
# Do NOT commit .env.local.
# --------------------------------------------------

NEXT_PUBLIC_ENV="dev"

# ----------------------------
# Public configuration
# ----------------------------
NEXT_PUBLIC_IOS_STORE_URL="https://apps.apple.com/app/idXXXXXXXXX"
NEXT_PUBLIC_ANDROID_STORE_URL="https://play.google.com/store/apps/details?id=com.makinglifeeasie.kinly"
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
NEXT_PUBLIC_APP_DEEP_LINK_SCHEME="kinly://"
NEXT_PUBLIC_TODAY_FALLBACK_URL="https://makinglifeeasie.com/today"
NEXT_PUBLIC_SUPPORTED_COUNTRIES="NZ,SG"

# ----------------------------
# Supabase (DEV by default)
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<dev-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<dev-public-anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<dev-service-role-key>"
# Public norms artifacts resolve from:
# ${NEXT_PUBLIC_SUPABASE_URL}/storage/v1/object/public/households/public_norms/home/{home_public_id}/...

# ----------------------------
# Piano landing
# ----------------------------
NEXT_PUBLIC_PIANO_VIDEO_CLASSICAL_URL="https://www.youtube-nocookie.com/embed/VIDEO_ID?rel=0"
NEXT_PUBLIC_PIANO_VIDEO_CHILDREN_URL="https://www.youtube-nocookie.com/embed/VIDEO_ID?rel=0"
NEXT_PUBLIC_PIANO_VIDEO_WEDDING_URL="https://www.youtube-nocookie.com/embed/VIDEO_ID?rel=0"
PIANO_NOTIFY_TO_EMAIL="teacher@example.com"
PIANO_NOTIFY_FROM_EMAIL="noreply@example.com"
RESEND_API_KEY="re_xxxxxxxxxxxxx"

# ----------------------------
# Feature flags
# ----------------------------
NEXT_PUBLIC_ENABLE_PUBLIC_NORMS="true"
